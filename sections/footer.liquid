<footer class="site-footer">
  <div class="footer__container">
    {% for block in section.blocks %}
      <div class="footer__column">
        {% case block.type %}
          {% when 'menu' %}<h4>{{ block.settings.heading }}</h4><ul class="footer__menu">{% for link in block.settings.menu.links %}<li><a href="{{ link.url }}">{{ link.title }}</a></li>{% endfor %}</ul>
          {% when 'newsletter' %}<h4>{{ block.settings.heading }}</h4>{% form 'customer' %}<input type="email" name="contact[email]" placeholder="Email" required><button type="submit" class="btn btn--primary">Subscribe</button>{% endform %}
        {% endcase %}
      </div>
    {% endfor %}
  </div>
  <div class="footer__bottom"><p>&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}</p></div>
</footer>
{% schema %}
{"name":"Footer","blocks":[{"type":"menu","name":"Menu","settings":[{"type":"text","id":"heading","label":"Heading"},{"type":"link_list","id":"menu","label":"Menu"}]},{"type":"newsletter","name":"Newsletter","settings":[{"type":"text","id":"heading","label":"Heading","default":"Subscribe"}]}]}
{% endschema %}
